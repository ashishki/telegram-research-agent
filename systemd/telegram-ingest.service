# Validated: systemd-analyze verify (run manually before deploying)
[Unit]
Description=Telegram Research Agent — Ingestion Pipeline
After=network.target

[Service]
Type=simple
User=oc_you
Group=oc_you
WorkingDirectory=/srv/openclaw-you/workspace/telegram-research-agent
EnvironmentFile=/srv/openclaw-you/.env
Environment=PYTHONPATH=/srv/openclaw-you/workspace/telegram-research-agent
ExecStart=/usr/bin/python3 src/main.py ingest
Restart=no
StandardOutput=journal
StandardError=journal
SyslogIdentifier=telegram-ingest
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/srv/openclaw-you/workspace/telegram-research-agent/data
ReadWritePaths=/srv/openclaw-you/secrets

[Install]
WantedBy=multi-user.target
